# Local development
VITE_SERVER_URL=http://localhost:8000
VITE_LAN_IP=192.168.29.250

# Production — set this to your deployed backend URL (e.g. Render)
# VITE_SERVER_URL=https://chat-server-xxxx.onrender.com

# Optional: for reliable WebRTC on strict NAT/mobile networks (TURN/STUN)
# VITE_ICE_SERVERS_JSON=[{"urls":["stun:stun.l.google.com:19302"]},{"urls":["turn:openrelay.metered.ca:80"],"username":"openrelayproject","credential":"openrelayproject"}]
# Optional call ring timeout (ms)
# VITE_CALL_RING_TIMEOUT_MS=30000
