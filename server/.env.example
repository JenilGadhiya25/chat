PORT=5000
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/chatapp
# Alternative name supported by some hosts:
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/chatapp
# Optional: retry interval (ms) for automatic Mongo reconnect in production
# MONGO_RETRY_MS=10000
# Optional: force DNS lookup family (4 helps on some hosts)
# MONGO_FAMILY=4
JWT_SECRET=your_jwt_secret_here
CLIENT_URL=http://localhost:5173
# Optional: comma-separated list of allowed frontend URLs
# CLIENT_URLS=https://your-app.netlify.app,https://preview-branch.netlify.app

# AI assistant (optional)
OPENAI_API_KEY=your_openai_api_key
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_IMAGE_MODEL=gpt-image-1

# Cloudinary (for media uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
